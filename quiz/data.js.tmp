[{"id":1,"week":"Week 1 Part 1 Quiz Questions \\& Answers","question":"What do APIs enable between different software systems?","answer_letter":"N","answer":"Communication and data sharing","explanation":"解析：API（应用程序接口）的核心作用是实现不同软件系统之间的通信和数据共享。"},{"id":2,"week":"Week 1 Part 1 Quiz Questions \\& Answers","question":"What is a RESTful API mainly used for?","answer_letter":"K","answer":"Request-response communication","explanation":"解析：RESTful API 遵循 REST 架构风格，主要用于请求-响应模式的通信。"},{"id":3,"week":"Week 1 Part 1 Quiz Questions \\& Answers","question":"What do Stream APIs provide?","answer_letter":"E","answer":"Real-time data streaming","explanation":"解析：Stream API 专为实时数据流传输设计，如实时推文流。"},{"id":4,"week":"Week 1 Part 1 Quiz Questions \\& Answers","question":"What format is commonly used in API responses?","answer_letter":"O","answer":"JSON","explanation":"解析：JSON（JavaScript Object Notation）是 API 响应中最常见的数据格式，轻量且易解析。"},{"id":5,"week":"Week 1 Part 1 Quiz Questions \\& Answers","question":"What is OAuth used for?","answer_letter":"A","answer":"Secure authentication and authorization","explanation":"解析：OAuth 是一种授权协议，允许应用安全地访问用户资源，无需暴露密码。"},{"id":6,"week":"Week 1 Part 1 Quiz Questions \\& Answers","question":"What does an API endpoint represent?","answer_letter":"H","answer":"A specific API URL","explanation":"解析：API 端点（Endpoint）是一个特定的 URL，代表 API 中可访问的资源或功能。"},{"id":7,"week":"Week 1 Part 1 Quiz Questions \\& Answers","question":"What is required before accessing most APIs?","answer_letter":"C","answer":"API credentials","explanation":"解析：大多数 API 需要凭证（如 API Key）来验证请求者身份。"},{"id":8,"week":"Week 1 Part 1 Quiz Questions \\& Answers","question":"What is a common challenge when using APIs?","answer_letter":"G","answer":"Rate limits","explanation":"解析：速率限制（Rate Limit）是 API 常见挑战，防止滥用，如 Twitter API 有每15分钟请求次数限制。"},{"id":9,"week":"Week 1 Part 1 Quiz Questions \\& Answers","question":"What Python library simplifies Twitter API usage?","answer_letter":"L","answer":"Tweepy","explanation":"解析：Tweepy 是 Python 中专门封装 Twitter API 的库，大幅简化调用流程。"},{"id":10,"week":"Week 1 Part 1 Quiz Questions \\& Answers","question":"What does the GitHub API provide access to?","answer_letter":"F","answer":"Repository and developer data","explanation":"解析：GitHub API 提供对仓库、提交、开发者等数据的访问。"},{"id":11,"week":"Week 1 Part 1 Quiz Questions \\& Answers","question":"What type of data can the YouTube API retrieve?","answer_letter":"D","answer":"Video and comment data","explanation":"解析：YouTube Data API 可获取视频信息、评论、频道统计等数据。"},{"id":12,"week":"Week 1 Part 1 Quiz Questions \\& Answers","question":"What is JSON parsing used for?","answer_letter":"B","answer":"Extracting information from JSON","explanation":"解析：JSON 解析将 JSON 字符串转换为程序可操作的数据结构，用于提取所需信息。"},{"id":13,"week":"Week 1 Part 1 Quiz Questions \\& Answers","question":"Why is data normalization important?","answer_letter":"I","answer":"Ensures consistency","explanation":"解析：数据归一化确保数据格式统一，提高分析一致性和准确性。"},{"id":14,"week":"Week 1 Part 1 Quiz Questions \\& Answers","question":"What does tokenization do in text processing?","answer_letter":"J","answer":"Splits text into words","explanation":"解析：分词（Tokenization）将文本分割成词语或子词单元，是 NLP 的基础步骤。"},{"id":15,"week":"Week 1 Part 1 Quiz Questions \\& Answers","question":"Why is MongoDB suitable for social media data?","answer_letter":"M","answer":"Flexible storage for unstructured data","explanation":"解析：MongoDB 是 NoSQL 数据库，采用灵活的文档模型，适合存储结构不固定的社交媒体数据。"},{"id":16,"week":"Week 1 Part 2 Quiz Questions & Answers","question":"How is structured data organized?","answer_letter":"E","answer":"Tables or databases","explanation":"解析：答案为「Tables or databases」。"},{"id":17,"week":"Week 1 Part 2 Quiz Questions & Answers","question":"What is an example of unstructured social media data?","answer_letter":"A","answer":"Text posts","explanation":"解析：答案为「Text posts」。"},{"id":18,"week":"Week 1 Part 2 Quiz Questions & Answers","question":"Why is data normalization important?","answer_letter":"K","answer":"Ensures consistency","explanation":"解析：数据归一化确保数据格式统一，提高分析一致性和准确性。"},{"id":19,"week":"Week 1 Part 2 Quiz Questions & Answers","question":"What does tokenization do?","answer_letter":"C","answer":"Splits text into tokens","explanation":"解析：分词（Tokenization）将文本分割成词语或子词单元，是 NLP 的基础步骤。"},{"id":20,"week":"Week 1 Part 2 Quiz Questions & Answers","question":"What are stop words?","answer_letter":"G","answer":"Common words with little meaning","explanation":"解析：答案为「Common words with little meaning」。"},{"id":21,"week":"Week 1 Part 2 Quiz Questions & Answers","question":"What is stemming used for?","answer_letter":"J","answer":"Reducing words to roots","explanation":"解析：答案为「Reducing words to roots」。"},{"id":22,"week":"Week 1 Part 2 Quiz Questions & Answers","question":"What does lemmatization consider?","answer_letter":"N","answer":"Dictionary meaning and context","explanation":"解析：答案为「Dictionary meaning and context」。"},{"id":23,"week":"Week 1 Part 2 Quiz Questions & Answers","question":"Why is removing duplicates important?","answer_letter":"H","answer":"Prevents biased or skewed analysis","explanation":"解析：答案为「Prevents biased or skewed analysis」。"},{"id":24,"week":"Week 1 Part 2 Quiz Questions & Answers","question":"What does exact matching identify?","answer_letter":"O","answer":"Identical records","explanation":"解析：答案为「Identical records」。"},{"id":25,"week":"Week 1 Part 2 Quiz Questions & Answers","question":"What type of database is MongoDB?","answer_letter":"D","answer":"NoSQL database","explanation":"解析：答案为「NoSQL database」。  NoSQL 数据库适合非结构化数据存储。"},{"id":26,"week":"Week 1 Part 2 Quiz Questions & Answers","question":"Why is MongoDB suitable for social media data?","answer_letter":"L","answer":"Flexible storage for unstructured data","explanation":"解析：MongoDB 是 NoSQL 数据库，采用灵活的文档模型，适合存储结构不固定的社交媒体数据。"},{"id":27,"week":"Week 1 Part 2 Quiz Questions & Answers","question":"What format does MongoDB use for documents?","answer_letter":"F","answer":"JSON-like documents","explanation":"解析：答案为「JSON-like documents」。  JSON 是最通用的数据交换格式。"},{"id":28,"week":"Week 1 Part 2 Quiz Questions & Answers","question":"What Python library connects Python to MongoDB?","answer_letter":"M","answer":"PyMongo","explanation":"解析：答案为「PyMongo」。"},{"id":29,"week":"Week 1 Part 2 Quiz Questions & Answers","question":"What does insert_one() do in MongoDB?","answer_letter":"B","answer":"Inserts one document","explanation":"解析：答案为「Inserts one document」。"},{"id":30,"week":"Week 1 Part 2 Quiz Questions & Answers","question":"What does find() do in MongoDB?","answer_letter":"I","answer":"Retrieves documents from a collection","explanation":"解析：答案为「Retrieves documents from a collection」。"},{"id":31,"week":"Week 2 Part 1","question":"What does API stand for?","answer_letter":"K","answer":"Application Programming Interface","explanation":"解析：答案为「Application Programming Interface」。"},{"id":32,"week":"Week 2 Part 1","question":"Why are APIs important in modern systems?","answer_letter":"B","answer":"They enable communication and data sharing between software","explanation":"解析：答案为「They enable communication and data sharing between software」。"},{"id":33,"week":"Week 2 Part 1","question":"What are the main components of an API request?","answer_letter":"G","answer":"Endpoint URL, HTTP method, headers, authentication token, and request body","explanation":"解析：答案为「Endpoint URL, HTTP method, headers, authentication token, and request body」。"},{"id":34,"week":"Week 2 Part 1","question":"Which HTTP method is used to create new data?","answer_letter":"E","answer":"POST","explanation":"解析：答案为「POST」。"},{"id":35,"week":"Week 2 Part 1","question":"What does the HTTP status code 401 indicate?","answer_letter":"H","answer":"Unauthorized access due to missing or invalid authentication","explanation":"解析：答案为「Unauthorized access due to missing or invalid authentication」。"},{"id":36,"week":"Week 2 Part 1","question":"What HTTP status code represents \"Too Many Requests\"?","answer_letter":"A","answer":"429","explanation":"解析：答案为「429」。"},{"id":37,"week":"Week 2 Part 1","question":"What is the main purpose of OAuth?","answer_letter":"I","answer":"To securely authorize applications without sharing passwords","explanation":"解析：答案为「To securely authorize applications without sharing passwords」。"},{"id":38,"week":"Week 2 Part 1","question":"Which version of OAuth is easier to implement?","answer_letter":"N","answer":"OAuth 2.0","explanation":"解析：答案为「OAuth 2.0」。"},{"id":39,"week":"Week 2 Part 1","question":"What is application authentication mainly used for?","answer_letter":"M","answer":"Machine-to-machine communication without user interaction","explanation":"解析：答案为「Machine-to-machine communication without user interaction」。"},{"id":40,"week":"Week 2 Part 1","question":"What is the purpose of user authentication in OAuth systems?","answer_letter":"L","answer":"To securely access user-specific data through delegated authorization","explanation":"解析：答案为「To securely access user-specific data through delegated authorization」。"},{"id":41,"week":"Week 2 Part 1","question":"What type of API is best suited for real-time updates?","answer_letter":"O","answer":"Stream APIs","explanation":"解析：答案为「Stream APIs」。"},{"id":42,"week":"Week 2 Part 1","question":"What architectural style do RESTful APIs follow?","answer_letter":"D","answer":"Representational State Transfer (REST)","explanation":"解析：答案为「Representational State Transfer (REST)」。"},{"id":43,"week":"Week 2 Part 1","question":"What does statelessness mean in REST APIs?","answer_letter":"J","answer":"The server does not store client session information between requests","explanation":"解析：答案为「The server does not store client session information between requests」。"},{"id":44,"week":"Week 2 Part 1","question":"What is one example use case for Stream APIs?","answer_letter":"C","answer":"Monitoring live Twitter feeds or real-time social media trends","explanation":"解析：答案为「Monitoring live Twitter feeds or real-time social media trends」。"},{"id":45,"week":"Week 2 Part 1","question":"Why do social media APIs use rate limits?","answer_letter":"F","answer":"To prevent abuse and maintain service availability","explanation":"解析：答案为「To prevent abuse and maintain service availability」。"},{"id":46,"week":"Week 2 Part 2","question":"What type of information can be retrieved from the YouTube Data API?","answer_letter":"I","answer":"Video details, comments, and channel statistics","explanation":"解析：答案为「Video details, comments, and channel statistics」。"},{"id":47,"week":"Week 2 Part 2","question":"What data format is most commonly returned by APIs?","answer_letter":"H","answer":"JSON","explanation":"解析：答案为「JSON」。  JSON 是最通用的数据交换格式。"},{"id":48,"week":"Week 2 Part 2","question":"What Python function is used to convert a JSON string into a Python object?","answer_letter":"B","answer":"json.loads()","explanation":"解析：答案为「json.loads()」。  JSON 是最通用的数据交换格式。"},{"id":49,"week":"Week 2 Part 2","question":"Why is data minimization important in ethical data acquisition?","answer_letter":"K","answer":"Because only necessary data should be collected for the intended purpose","explanation":"解析：答案为「Because only necessary data should be collected for the intended purpose」。"},{"id":50,"week":"Week 2 Part 2","question":"What are two important privacy regulations mentioned in the slides?","answer_letter":"N","answer":"GDPR and CCPA","explanation":"解析：答案为「GDPR and CCPA」。"},{"id":51,"week":"Week 2 Part 2","question":"What is the first step in the data acquisition workflow?","answer_letter":"O","answer":"Registering the application","explanation":"解析：答案为「Registering the application」。"},{"id":52,"week":"Week 2 Part 2","question":"Why do developers need API credentials?","answer_letter":"L","answer":"To authenticate and securely access the API","explanation":"解析：答案为「To authenticate and securely access the API」。"},{"id":53,"week":"Week 2 Part 2","question":"What is the purpose of query parameters in API requests?","answer_letter":"E","answer":"To customize and filter returned data","explanation":"解析：答案为「To customize and filter returned data」。"},{"id":54,"week":"Week 2 Part 2","question":"Which parameter is commonly used to limit the number of results returned?","answer_letter":"M","answer":"maxResults","explanation":"解析：答案为「maxResults」。"},{"id":55,"week":"Week 2 Part 2","question":"What Python library is used in the slides for interacting with Twitter APIs?","answer_letter":"J","answer":"Tweepy","explanation":"解析：答案为「Tweepy」。"},{"id":56,"week":"Week 2 Part 2","question":"What type of Twitter data can be retrieved using the API?","answer_letter":"G","answer":"Tweets, user profiles, follower information, and trends","explanation":"解析：答案为「Tweets, user profiles, follower information, and trends」。"},{"id":57,"week":"Week 2 Part 2","question":"What is required before using the Facebook Graph API?","answer_letter":"F","answer":"An access token","explanation":"解析：答案为「An access token」。"},{"id":58,"week":"Week 2 Part 2","question":"What is the GitHub API example searching for?","answer_letter":"D","answer":"Trending Python repositories sorted by stars","explanation":"解析：答案为「Trending Python repositories sorted by stars」。"},{"id":59,"week":"Week 2 Part 2","question":"Which Python library is used to send HTTP requests in the GitHub example?","answer_letter":"C","answer":"requests","explanation":"解析：答案为「requests」。"},{"id":60,"week":"Week 3.1 - First Part Quiz Questions & Answers","question":"What is the main purpose of Exploratory Data Analysis (EDA)?","answer_letter":"O","answer":"Understanding patterns and characteristics","explanation":"解析：答案为「Understanding patterns and characteristics」。"},{"id":61,"week":"Week 3.1 - First Part Quiz Questions & Answers","question":"Why is data cleaning important before analysis?","answer_letter":"H","answer":"It improves data quality and reliability","explanation":"解析：答案为「It improves data quality and reliability」。"},{"id":62,"week":"Week 3.1 - First Part Quiz Questions & Answers","question":"What is the goal of data acquisition in the EDA workflow?","answer_letter":"B","answer":"Collecting data from different sources","explanation":"解析：答案为「Collecting data from different sources」。"},{"id":63,"week":"Week 3.1 - First Part Quiz Questions & Answers","question":"What happens during the data transformation stage?","answer_letter":"G","answer":"Standardizing inconsistent data formats","explanation":"解析：答案为「Standardizing inconsistent data formats」。"},{"id":64,"week":"Week 3.1 - First Part Quiz Questions & Answers","question":"What is one common source of structured data?","answer_letter":"E","answer":"SQL and NoSQL databases","explanation":"解析：答案为「SQL and NoSQL databases」。  NoSQL 数据库适合非结构化数据存储。"},{"id":65,"week":"Week 3.1 - First Part Quiz Questions & Answers","question":"What type of data includes tweets, reviews, and images?","answer_letter":"D","answer":"Unstructured data","explanation":"解析：答案为「Unstructured data」。"},{"id":66,"week":"Week 3.1 - First Part Quiz Questions & Answers","question":"What problem can outliers cause in analysis?","answer_letter":"C","answer":"Distorted statistics and misleading trends","explanation":"解析：答案为「Distorted statistics and misleading trends」。"},{"id":67,"week":"Week 3.1 - First Part Quiz Questions & Answers","question":"Which visualization is best for understanding data distributions?","answer_letter":"L","answer":"Histogram","explanation":"解析：答案为「Histogram」。"},{"id":68,"week":"Week 3.1 - First Part Quiz Questions & Answers","question":"Which chart is commonly used to compare categories?","answer_letter":"N","answer":"Bar chart","explanation":"解析：答案为「Bar chart」。"},{"id":69,"week":"Week 3.1 - First Part Quiz Questions & Answers","question":"Which visualization helps identify relationships between variables?","answer_letter":"F","answer":"Scatterplot","explanation":"解析：答案为「Scatterplot」。"},{"id":70,"week":"Week 3.1 - First Part Quiz Questions & Answers","question":"Which visualization is most useful for detecting outliers?","answer_letter":"I","answer":"Boxplot","explanation":"解析：答案为「Boxplot」。"},{"id":71,"week":"Week 3.1 - First Part Quiz Questions & Answers","question":"What is data normalization used for?","answer_letter":"M","answer":"Preparing data for analysis and visualization","explanation":"解析：答案为「Preparing data for analysis and visualization」。"},{"id":72,"week":"Week 3.1 - First Part Quiz Questions & Answers","question":"What is one common indicator of missing values?","answer_letter":"A","answer":"Null or NaN values","explanation":"解析：答案为「Null or NaN values」。"},{"id":73,"week":"Week 3.1 - First Part Quiz Questions & Answers","question":"What is the purpose of removing duplicate records?","answer_letter":"J","answer":"Preventing inaccurate analysis results","explanation":"解析：答案为「Preventing inaccurate analysis results」。"},{"id":74,"week":"Week 3.1 - First Part Quiz Questions & Answers","question":"What is the main purpose of summary statistics in EDA?","answer_letter":"K","answer":"Understanding datasets numerically","explanation":"解析：答案为「Understanding datasets numerically」。"},{"id":75,"week":"Week 3.1 - Second Part Quiz Questions & Answers","question":"What is the main purpose of Pandas DataFrames in Python?","answer_letter":"M","answer":"Storing and manipulating tabular data","explanation":"解析：答案为「Storing and manipulating tabular data」。"},{"id":76,"week":"Week 3.1 - Second Part Quiz Questions & Answers","question":"What does df.head() display in Pandas?","answer_letter":"F","answer":"The first rows of a dataset","explanation":"解析：答案为「The first rows of a dataset」。"},{"id":77,"week":"Week 3.1 - Second Part Quiz Questions & Answers","question":"What information does df.describe() provide?","answer_letter":"J","answer":"Summary statistics for numerical columns","explanation":"解析：答案为「Summary statistics for numerical columns」。"},{"id":78,"week":"Week 3.1 - Second Part Quiz Questions & Answers","question":"What is df.isnull().sum() used for?","answer_letter":"D","answer":"Counting missing values in each column","explanation":"解析：答案为「Counting missing values in each column」。"},{"id":79,"week":"Week 3.1 - Second Part Quiz Questions & Answers","question":"What does drop_duplicates() do in Pandas?","answer_letter":"H","answer":"Removes duplicated rows","explanation":"解析：答案为「Removes duplicated rows」。"},{"id":80,"week":"Week 3.1 - Second Part Quiz Questions & Answers","question":"Why are histograms useful in EDA?","answer_letter":"C","answer":"Visualizing data distributions","explanation":"解析：答案为「Visualizing data distributions」。"},{"id":81,"week":"Week 3.1 - Second Part Quiz Questions & Answers","question":"What does a scatter plot help identify?","answer_letter":"L","answer":"Relationships between variables","explanation":"解析：答案为「Relationships between variables」。"},{"id":82,"week":"Week 3.1 - Second Part Quiz Questions & Answers","question":"What is the main purpose of box plots?","answer_letter":"G","answer":"Detecting outliers and variability","explanation":"解析：答案为「Detecting outliers and variability」。"},{"id":83,"week":"Week 3.1 - Second Part Quiz Questions & Answers","question":"What type of chart is best for comparing categories?","answer_letter":"O","answer":"Bar chart","explanation":"解析：答案为「Bar chart」。"},{"id":84,"week":"Week 3.1 - Second Part Quiz Questions & Answers","question":"Which Python library provides advanced statistical visualizations?","answer_letter":"A","answer":"Seaborn","explanation":"解析：答案为「Seaborn」。"},{"id":85,"week":"Week 3.1 - Second Part Quiz Questions & Answers","question":"Why is data cleaning important before analysis?","answer_letter":"I","answer":"Preparing reliable datasets","explanation":"解析：答案为「Preparing reliable datasets」。"},{"id":86,"week":"Week 3.1 - Second Part Quiz Questions & Answers","question":"What is a key advantage of NoSQL databases?","answer_letter":"E","answer":"Flexible schema design","explanation":"解析：答案为「Flexible schema design」。"},{"id":87,"week":"Week 3.1 - Second Part Quiz Questions & Answers","question":"What does insert_one() do in MongoDB?","answer_letter":"K","answer":"Inserts a single document","explanation":"解析：答案为「Inserts a single document」。"},{"id":88,"week":"Week 3.1 - Second Part Quiz Questions & Answers","question":"What is PyMongo used for in Python?","answer_letter":"B","answer":"Connecting Python with MongoDB","explanation":"解析：答案为「Connecting Python with MongoDB」。  NoSQL 数据库适合非结构化数据存储。"},{"id":89,"week":"Week 3.1 - Second Part Quiz Questions & Answers","question":"What is the goal of exploratory data analysis (EDA)?","answer_letter":"N","answer":"Finding patterns and trends","explanation":"解析：答案为「Finding patterns and trends」。"},{"id":90,"week":"Week 3.2 - First Part Quiz Questions & Answers","question":"What is the purpose of data annotation in AI systems?","answer_letter":"I","answer":"Creating labeled training data","explanation":"解析：答案为「Creating labeled training data」。"},{"id":91,"week":"Week 3.2 - First Part Quiz Questions & Answers","question":"Why is high-quality annotation important for AI?","answer_letter":"G","answer":"Improving accuracy and reliability","explanation":"解析：答案为「Improving accuracy and reliability」。"},{"id":92,"week":"Week 3.2 - First Part Quiz Questions & Answers","question":"What happens during the data preprocessing stage?","answer_letter":"C","answer":"Cleaning and organizing raw data","explanation":"解析：答案为「Cleaning and organizing raw data」。"},{"id":93,"week":"Week 3.2 - First Part Quiz Questions & Answers","question":"What does sentiment annotation classify in text?","answer_letter":"F","answer":"Emotional tone or opinion","explanation":"解析：答案为「Emotional tone or opinion」。"},{"id":94,"week":"Week 3.2 - First Part Quiz Questions & Answers","question":"What is keyword annotation used for?","answer_letter":"B","answer":"Highlighting important words or phrases","explanation":"解析：答案为「Highlighting important words or phrases」。"},{"id":95,"week":"Week 3.2 - First Part Quiz Questions & Answers","question":"What is named entity annotation designed to identify?","answer_letter":"N","answer":"People, locations, and organizations","explanation":"解析：答案为「People, locations, and organizations」。"},{"id":96,"week":"Week 3.2 - First Part Quiz Questions & Answers","question":"What type of annotation assigns categories such as spam or not spam?","answer_letter":"L","answer":"Text classification","explanation":"解析：答案为「Text classification」。"},{"id":97,"week":"Week 3.2 - First Part Quiz Questions & Answers","question":"What is the main goal of object detection in computer vision?","answer_letter":"H","answer":"Locating objects in images","explanation":"解析：答案为「Locating objects in images」。"},{"id":98,"week":"Week 3.2 - First Part Quiz Questions & Answers","question":"What does semantic segmentation do in image annotation?","answer_letter":"K","answer":"Labels every pixel in an image","explanation":"解析：答案为「Labels every pixel in an image」。"},{"id":99,"week":"Week 3.2 - First Part Quiz Questions & Answers","question":"What is video tracking used for in AI systems?","answer_letter":"M","answer":"Following objects across video frames","explanation":"解析：答案为「Following objects across video frames」。"},{"id":100,"week":"Week 3.2 - First Part Quiz Questions & Answers","question":"What is the purpose of speaker identification in audio annotation?","answer_letter":"O","answer":"Detecting who is speaking","explanation":"解析：答案为「Detecting who is speaking」。"},{"id":101,"week":"Week 3.2 - First Part Quiz Questions & Answers","question":"How does audio transcription help AI systems?","answer_letter":"A","answer":"Converting speech into written text","explanation":"解析：答案为「Converting speech into written text」。"},{"id":102,"week":"Week 3.2 - First Part Quiz Questions & Answers","question":"What is a real-world use case of bounding boxes in autonomous driving?","answer_letter":"D","answer":"Detecting vehicles and pedestrians","explanation":"解析：答案为「Detecting vehicles and pedestrians」。"},{"id":103,"week":"Week 3.2 - First Part Quiz Questions & Answers","question":"How can AI support agriculture using image annotation?","answer_letter":"E","answer":"Detecting crop diseases and plant health","explanation":"解析：答案为「Detecting crop diseases and plant health」。"},{"id":104,"week":"Week 3.2 - First Part Quiz Questions & Answers","question":"Which open-source tool is commonly used for text annotation?","answer_letter":"J","answer":"Doccano","explanation":"解析：答案为「Doccano」。"},{"id":105,"week":"Week 4.1 - First Part Quiz Questions & Answers","question":"What is Sentiment Analysis?","answer_letter":"F","answer":"Identifying emotions and opinions in text","explanation":"解析：答案为「Identifying emotions and opinions in text」。"},{"id":106,"week":"Week 4.1 - First Part Quiz Questions & Answers","question":"What are the main sentiment categories?","answer_letter":"B","answer":"Positive, Negative, Neutral","explanation":"解析：答案为「Positive, Negative, Neutral」。"},{"id":107,"week":"Week 4.1 - First Part Quiz Questions & Answers","question":"What is Aspect-Based Sentiment Analysis (ABSA)?","answer_letter":"M","answer":"Detecting sentiment toward specific features","explanation":"解析：答案为「Detecting sentiment toward specific features」。  情感分析识别文本中的情绪倾向。"},{"id":108,"week":"Week 4.1 - First Part Quiz Questions & Answers","question":"What is the purpose of preprocessing?","answer_letter":"I","answer":"Clean and normalize text","explanation":"解析：答案为「Clean and normalize text」。"},{"id":109,"week":"Week 4.1 - First Part Quiz Questions & Answers","question":"What does tokenization do?","answer_letter":"G","answer":"Splits text into smaller units","explanation":"解析：分词（Tokenization）将文本分割成词语或子词单元，是 NLP 的基础步骤。"},{"id":110,"week":"Week 4.1 - First Part Quiz Questions & Answers","question":"What is a stopword?","answer_letter":"D","answer":"Common words with little meaning","explanation":"解析：答案为「Common words with little meaning」。"},{"id":111,"week":"Week 4.1 - First Part Quiz Questions & Answers","question":"What does normalization improve?","answer_letter":"N","answer":"Text consistency","explanation":"解析：答案为「Text consistency」。"},{"id":112,"week":"Week 4.1 - First Part Quiz Questions & Answers","question":"What is TF-IDF used for?","answer_letter":"C","answer":"Measuring word importance","explanation":"解析：答案为「Measuring word importance」。"},{"id":113,"week":"Week 4.1 - First Part Quiz Questions & Answers","question":"What is a unigram?","answer_letter":"J","answer":"Single word","explanation":"解析：答案为「Single word」。"},{"id":114,"week":"Week 4.1 - First Part Quiz Questions & Answers","question":"What is a bigram?","answer_letter":"H","answer":"Two-word sequence","explanation":"解析：答案为「Two-word sequence」。"},{"id":115,"week":"Week 4.1 - First Part Quiz Questions & Answers","question":"What is a trigram?","answer_letter":"E","answer":"Three-word sequence","explanation":"解析：答案为「Three-word sequence」。"},{"id":116,"week":"Week 4.1 - First Part Quiz Questions & Answers","question":"What does VADER analyze well?","answer_letter":"A","answer":"Social media text","explanation":"解析：答案为「Social media text」。"},{"id":117,"week":"Week 4.1 - First Part Quiz Questions & Answers","question":"What is the VADER compound score range?","answer_letter":"O","answer":"-1 to +1","explanation":"解析：答案为「-1 to +1」。"},{"id":118,"week":"Week 4.1 - First Part Quiz Questions & Answers","question":"What does Naive Bayes assume?","answer_letter":"K","answer":"Features are independent","explanation":"解析：答案为「Features are independent」。"},{"id":119,"week":"Week 4.1 - First Part Quiz Questions & Answers","question":"What is Precision?","answer_letter":"L","answer":"Correct positive predictions","explanation":"解析：答案为「Correct positive predictions」。"},{"id":120,"week":"Week 4.2 - First Part Quiz Questions & Answers","question":"What is Sentiment Analysis?","answer_letter":"N","answer":"Identifying emotions and opinions in text","explanation":"解析：答案为「Identifying emotions and opinions in text」。"},{"id":121,"week":"Week 4.2 - First Part Quiz Questions & Answers","question":"What are the main sentiment categories?","answer_letter":"L","answer":"Positive, Neutral, Negative","explanation":"解析：答案为「Positive, Neutral, Negative」。"},{"id":122,"week":"Week 4.2 - First Part Quiz Questions & Answers","question":"What is Opinion Mining?","answer_letter":"B","answer":"Another name for Sentiment Analysis","explanation":"解析：答案为「Another name for Sentiment Analysis」。  情感分析识别文本中的情绪倾向。"},{"id":123,"week":"Week 4.2 - First Part Quiz Questions & Answers","question":"Why is context important in sentiment analysis?","answer_letter":"A","answer":"Words can change meaning depending on context","explanation":"解析：答案为「Words can change meaning depending on context」。"},{"id":124,"week":"Week 4.2 - First Part Quiz Questions & Answers","question":"What is sarcasm in sentiment analysis?","answer_letter":"H","answer":"Positive words expressing negative intent","explanation":"解析：答案为「Positive words expressing negative intent」。"},{"id":125,"week":"Week 4.2 - First Part Quiz Questions & Answers","question":"What is negation?","answer_letter":"O","answer":"Negative words changing sentiment meaning","explanation":"解析：答案为「Negative words changing sentiment meaning」。  情感分析识别文本中的情绪倾向。"},{"id":126,"week":"Week 4.2 - First Part Quiz Questions & Answers","question":"What is Aspect-Based Sentiment Analysis (ABSA)?","answer_letter":"J","answer":"Detecting sentiment toward specific features","explanation":"解析：答案为「Detecting sentiment toward specific features」。  情感分析识别文本中的情绪倾向。"},{"id":127,"week":"Week 4.2 - First Part Quiz Questions & Answers","question":"Why is preprocessing important?","answer_letter":"E","answer":"Removes noise from text","explanation":"解析：答案为「Removes noise from text」。"},{"id":128,"week":"Week 4.2 - First Part Quiz Questions & Answers","question":"What do stopwords represent?","answer_letter":"C","answer":"Common low-information words","explanation":"解析：答案为「Common low-information words」。"},{"id":129,"week":"Week 4.2 - First Part Quiz Questions & Answers","question":"What does normalization do?","answer_letter":"M","answer":"Standardizes text format","explanation":"解析：答案为「Standardizes text format」。"},{"id":130,"week":"Week 4.2 - First Part Quiz Questions & Answers","question":"Why are N-grams useful?","answer_letter":"D","answer":"Capture phrase-level meaning","explanation":"解析：答案为「Capture phrase-level meaning」。"},{"id":131,"week":"Week 4.2 - First Part Quiz Questions & Answers","question":"What does TF measure?","answer_letter":"K","answer":"Word frequency in a document","explanation":"解析：答案为「Word frequency in a document」。"},{"id":132,"week":"Week 4.2 - First Part Quiz Questions & Answers","question":"What does IDF measure?","answer_letter":"G","answer":"Word rarity across documents","explanation":"解析：答案为「Word rarity across documents」。"},{"id":133,"week":"Week 4.2 - First Part Quiz Questions & Answers","question":"What is TF-IDF used for?","answer_letter":"F","answer":"Measuring important words","explanation":"解析：答案为「Measuring important words」。"},{"id":134,"week":"Week 4.2 - First Part Quiz Questions & Answers","question":"What is the VADER compound score range?","answer_letter":"I","answer":"-1 to +1","explanation":"解析：答案为「-1 to +1」。"},{"id":135,"week":"Week 4.2 Part 2","question":"Why are Decision Trees interpretable?","answer_letter":"A","answer":"They use rule-based decisions","explanation":"解析：答案为「They use rule-based decisions」。"},{"id":136,"week":"Week 4.2 Part 2","question":"What does Random Forest combine?","answer_letter":"O","answer":"Predictions from multiple trees","explanation":"解析：答案为「Predictions from multiple trees」。"},{"id":137,"week":"Week 4.2 Part 2","question":"What does TF-IDF represent?","answer_letter":"M","answer":"Numerical text features","explanation":"解析：答案为「Numerical text features」。"},{"id":138,"week":"Week 4.2 Part 2","question":"What metric measures overall correctness?","answer_letter":"E","answer":"Accuracy","explanation":"解析：答案为「Accuracy」。"},{"id":139,"week":"Week 4.2 Part 2","question":"What metric measures correct positive predictions?","answer_letter":"I","answer":"Precision","explanation":"解析：答案为「Precision」。  精确率 = 正确预测的正样本 / 所有预测为正的样本。"},{"id":140,"week":"Week 4.2 Part 2","question":"What is the purpose of Feature Extraction?","answer_letter":"F","answer":"Convert text into numerical vectors","explanation":"解析：答案为「Convert text into numerical vectors」。"},{"id":141,"week":"Week 4.2 Part 2","question":"What labels are commonly used in sentiment datasets?","answer_letter":"C","answer":"Positive, Negative, Neutral","explanation":"解析：答案为「Positive, Negative, Neutral」。"},{"id":142,"week":"Week 4.2 Part 2","question":"What does Naive Bayes calculate?","answer_letter":"G","answer":"Probabilities based on word frequencies","explanation":"解析：答案为「Probabilities based on word frequencies」。"},{"id":143,"week":"Week 4.2 Part 2","question":"What is the core idea of Logistic Regression?","answer_letter":"J","answer":"Learn a decision boundary between classes","explanation":"解析：答案为「Learn a decision boundary between classes」。"},{"id":144,"week":"Week 4.2 Part 2","question":"What does SVM try to maximize?","answer_letter":"K","answer":"Margin between sentiment classes","explanation":"解析：答案为「Margin between sentiment classes」。  情感分析识别文本中的情绪倾向。"},{"id":145,"week":"Week 4.2 Part 2","question":"What metric measures detected positive cases?","answer_letter":"B","answer":"Recall","explanation":"解析：答案为「Recall」。  召回率 = 正确预测的正样本 / 所有实际正样本。"},{"id":146,"week":"Week 4.2 Part 2","question":"What metric balances Precision and Recall?","answer_letter":"N","answer":"F1-Score","explanation":"解析：答案为「F1-Score」。  F1-Score 是精确率和召回率的调和平均值。"},{"id":147,"week":"Week 4.2 Part 2","question":"What problem can biased datasets create?","answer_letter":"D","answer":"Unfair predictions","explanation":"解析：答案为「Unfair predictions」。"},{"id":148,"week":"Week 4.2 Part 2","question":"Why is privacy important in sentiment analysis?","answer_letter":"L","answer":"Text may contain personal information","explanation":"解析：答案为「Text may contain personal information」。"},{"id":149,"week":"Week 4.2 Part 2","question":"What does VADER handle well?","answer_letter":"H","answer":"Social media slang and emojis","explanation":"解析：答案为「Social media slang and emojis」。"},{"id":150,"week":"Week 5.1 - First Part Quiz Questions & Answers","question":"What is the main limitation of Bag-of-Words?","answer_letter":"B","answer":"Ignores meaning and context","explanation":"解析：答案为「Ignores meaning and context」。"},{"id":151,"week":"Week 5.1 - First Part Quiz Questions & Answers","question":"What do word embeddings represent?","answer_letter":"G","answer":"Words as dense numerical vectors","explanation":"解析：答案为「Words as dense numerical vectors」。"},{"id":152,"week":"Week 5.1 - First Part Quiz Questions & Answers","question":"Why are similar words close in embedding space?","answer_letter":"A","answer":"They appear in similar contexts","explanation":"解析：答案为「They appear in similar contexts」。"},{"id":153,"week":"Week 5.1 - First Part Quiz Questions & Answers","question":"What is a key benefit of word embeddings?","answer_letter":"J","answer":"Capturing semantic relationships","explanation":"解析：答案为「Capturing semantic relationships」。"},{"id":154,"week":"Week 5.1 - First Part Quiz Questions & Answers","question":"What is the main advantage of deep learning for sentiment analysis?","answer_letter":"M","answer":"Learning patterns directly from data","explanation":"解析：答案为「Learning patterns directly from data」。"},{"id":155,"week":"Week 5.1 - First Part Quiz Questions & Answers","question":"What problem do LSTMs solve?","answer_letter":"F","answer":"Long-term dependency and memory issues","explanation":"解析：答案为「Long-term dependency and memory issues」。"},{"id":156,"week":"Week 5.1 - First Part Quiz Questions & Answers","question":"What do CNNs detect in text?","answer_letter":"N","answer":"Important phrases and local patterns","explanation":"解析：答案为「Important phrases and local patterns」。"},{"id":157,"week":"Week 5.1 - First Part Quiz Questions & Answers","question":"What is the purpose of the attention mechanism?","answer_letter":"L","answer":"Focusing on important words in context","explanation":"解析：答案为「Focusing on important words in context」。"},{"id":158,"week":"Week 5.1 - First Part Quiz Questions & Answers","question":"What architecture powers BERT and GPT models?","answer_letter":"D","answer":"Transformers","explanation":"解析：答案为「Transformers」。  Transformer 是 BERT/GPT 等大模型的基础架构。"},{"id":159,"week":"Week 5.1 - First Part Quiz Questions & Answers","question":"What does BERT understand better than traditional embeddings?","answer_letter":"C","answer":"Context-dependent word meaning","explanation":"解析：答案为「Context-dependent word meaning」。"},{"id":160,"week":"Week 5.1 - First Part Quiz Questions & Answers","question":"Why is Hugging Face popular in NLP?","answer_letter":"H","answer":"Provides easy access to pre-trained models","explanation":"解析：答案为「Provides easy access to pre-trained models」。"},{"id":161,"week":"Week 5.1 - First Part Quiz Questions & Answers","question":"What is an LLM (Large Language Model)?","answer_letter":"K","answer":"A large Transformer trained on massive text data","explanation":"解析：答案为「A large Transformer trained on massive text data」。  Transformer 是 BERT/GPT 等大模型的基础架构。"},{"id":162,"week":"Week 5.1 - First Part Quiz Questions & Answers","question":"What is the goal of multilingual sentiment analysis?","answer_letter":"O","answer":"Analyzing opinions across different languages","explanation":"解析：答案为「Analyzing opinions across different languages」。"},{"id":163,"week":"Week 5.1 - First Part Quiz Questions & Answers","question":"What does emotion detection identify beyond sentiment?","answer_letter":"I","answer":"Specific emotions such as joy or anger","explanation":"解析：答案为「Specific emotions such as joy or anger」。"},{"id":164,"week":"Week 5.1 - First Part Quiz Questions & Answers","question":"Why is sarcasm difficult for sentiment models?","answer_letter":"E","answer":"Literal words may express the opposite sentiment","explanation":"解析：答案为「Literal words may express the opposite sentiment」。  情感分析识别文本中的情绪倾向。"},{"id":165,"week":"Week 5.1 - Second Part Quiz Questions & Answers","question":"What is the purpose of Aspect-Based Sentiment Analysis (ABSA)?","answer_letter":"G","answer":"Analyze sentiment toward specific aspects","explanation":"解析：答案为「Analyze sentiment toward specific aspects」。  情感分析识别文本中的情绪倾向。"},{"id":166,"week":"Week 5.1 - Second Part Quiz Questions & Answers","question":"Why is Explainable AI (XAI) important?","answer_letter":"O","answer":"Explains why a model made a prediction","explanation":"解析：答案为「Explains why a model made a prediction」。"},{"id":167,"week":"Week 5.1 - Second Part Quiz Questions & Answers","question":"What does qualitative analysis provide beyond sentiment scores?","answer_letter":"K","answer":"Understanding of context and underlying meaning","explanation":"解析：答案为「Understanding of context and underlying meaning」。"},{"id":168,"week":"Week 5.1 - Second Part Quiz Questions & Answers","question":"What is a common challenge in advanced sentiment analysis?","answer_letter":"E","answer":"Detecting sarcasm and contextual meaning","explanation":"解析：答案为「Detecting sarcasm and contextual meaning」。"},{"id":169,"week":"Week 5.1 - Second Part Quiz Questions & Answers","question":"What is multilingual sentiment analysis?","answer_letter":"M","answer":"Analyzing sentiment across multiple languages","explanation":"解析：答案为「Analyzing sentiment across multiple languages」。  情感分析识别文本中的情绪倾向。"},{"id":170,"week":"Week 5.1 - Second Part Quiz Questions & Answers","question":"What does emotion detection identify?","answer_letter":"L","answer":"Specific emotions such as joy, anger, disgust","explanation":"解析：答案为「Specific emotions such as joy, anger, disgust」。"},{"id":171,"week":"Week 5.1 - Second Part Quiz Questions & Answers","question":"Why is sarcasm difficult to detect automatically?","answer_letter":"H","answer":"Literal words may differ from intended meaning","explanation":"解析：答案为「Literal words may differ from intended meaning」。"},{"id":172,"week":"Week 5.1 - Second Part Quiz Questions & Answers","question":"What NLP library was used in the sentiment analysis code example?","answer_letter":"B","answer":"spaCy","explanation":"解析：答案为「spaCy」。"},{"id":173,"week":"Week 5.1 - Second Part Quiz Questions & Answers","question":"What does Named Entity Recognition (NER) identify?","answer_letter":"A","answer":"Entities such as people, organizations, locations","explanation":"解析：答案为「Entities such as people, organizations, locations」。"},{"id":174,"week":"Week 5.1 - Second Part Quiz Questions & Answers","question":"What is a major application of sentiment analysis in e-commerce?","answer_letter":"I","answer":"Analyzing product reviews","explanation":"解析：答案为「Analyzing product reviews」。"},{"id":175,"week":"Week 5.1 - Second Part Quiz Questions & Answers","question":"What is multimodal sentiment analysis?","answer_letter":"N","answer":"Combining text, images, audio, and video","explanation":"解析：答案为「Combining text, images, audio, and video」。"},{"id":176,"week":"Week 5.1 - Second Part Quiz Questions & Answers","question":"Why can accuracy be misleading on imbalanced datasets?","answer_letter":"F","answer":"Majority classes can dominate predictions","explanation":"解析：答案为「Majority classes can dominate predictions」。"},{"id":177,"week":"Week 5.1 - Second Part Quiz Questions & Answers","question":"What metric is commonly used for imbalanced classification problems?","answer_letter":"D","answer":"F1-Score","explanation":"解析：答案为「F1-Score」。  F1-Score 是精确率和召回率的调和平均值。"},{"id":178,"week":"Week 5.1 - Second Part Quiz Questions & Answers","question":"What is an advantage of lexicon-based sentiment analysis?","answer_letter":"C","answer":"No training data required","explanation":"解析：答案为「No training data required」。"},{"id":179,"week":"Week 5.1 - Second Part Quiz Questions & Answers","question":"What is a future trend in sentiment analysis?","answer_letter":"J","answer":"Using Large Language Models for deeper understanding","explanation":"解析：答案为「Using Large Language Models for deeper understanding」。"},{"id":180,"week":"Week 5.2 - First Part Quiz Questions & Answers","question":"What type of learning uses labeled examples?","answer_letter":"I","answer":"Supervised learning","explanation":"解析：答案为「Supervised learning」。  监督学习使用带标签的数据进行训练。"},{"id":181,"week":"Week 5.2 - First Part Quiz Questions & Answers","question":"Why is supervised learning used in practice?","answer_letter":"L","answer":"Predict outcomes","explanation":"解析：答案为「Predict outcomes」。"},{"id":182,"week":"Week 5.2 - First Part Quiz Questions & Answers","question":"What are the two components of a labeled example?","answer_letter":"H","answer":"Features and labels","explanation":"解析：答案为「Features and labels」。"},{"id":183,"week":"Week 5.2 - First Part Quiz Questions & Answers","question":"What is the main objective of supervised learning?","answer_letter":"N","answer":"Predict new data","explanation":"解析：答案为「Predict new data」。"},{"id":184,"week":"Week 5.2 - First Part Quiz Questions & Answers","question":"What do we call the input variables of a model?","answer_letter":"J","answer":"Features","explanation":"解析：答案为「Features」。"},{"id":185,"week":"Week 5.2 - First Part Quiz Questions & Answers","question":"What do we call the output the model must predict?","answer_letter":"O","answer":"Label","explanation":"解析：答案为「Label」。"},{"id":186,"week":"Week 5.2 - First Part Quiz Questions & Answers","question":"What is a single row in a dataset called?","answer_letter":"B","answer":"Instance","explanation":"解析：答案为「Instance」。"},{"id":187,"week":"Week 5.2 - First Part Quiz Questions & Answers","question":"Why do we sample data before training?","answer_letter":"F","answer":"Representative data","explanation":"解析：答案为「Representative data」。"},{"id":188,"week":"Week 5.2 - First Part Quiz Questions & Answers","question":"Which sampling method preserves class proportions?","answer_letter":"D","answer":"Stratified sampling","explanation":"解析：答案为「Stratified sampling」。"},{"id":189,"week":"Week 5.2 - First Part Quiz Questions & Answers","question":"Why do we keep a separate test dataset?","answer_letter":"M","answer":"Unseen evaluation","explanation":"解析：答案为「Unseen evaluation」。"},{"id":190,"week":"Week 5.2 - First Part Quiz Questions & Answers","question":"What does a machine learning model learn from training data?","answer_letter":"G","answer":"Data patterns","explanation":"解析：答案为「Data patterns」。"},{"id":191,"week":"Week 5.2 - First Part Quiz Questions & Answers","question":"What is the first stage of a supervised learning project?","answer_letter":"K","answer":"Data collection","explanation":"解析：答案为「Data collection」。"},{"id":192,"week":"Week 5.2 - First Part Quiz Questions & Answers","question":"Which task predicts categories such as spam or not spam?","answer_letter":"E","answer":"Classification","explanation":"解析：答案为「Classification」。"},{"id":193,"week":"Week 5.2 - First Part Quiz Questions & Answers","question":"Which task predicts values such as house prices?","answer_letter":"A","answer":"Regression","explanation":"解析：答案为「Regression」。"},{"id":194,"week":"Week 5.2 - First Part Quiz Questions & Answers","question":"What process creates or improves input variables?","answer_letter":"C","answer":"Feature engineering","explanation":"解析：答案为「Feature engineering」。"},{"id":195,"week":"Week 5.2 Part 2","question":"What are features in a dataset?","answer_letter":"H","answer":"Input predictor variables","explanation":"解析：答案为「Input predictor variables」。"},{"id":196,"week":"Week 5.2 Part 2","question":"What are labels in a dataset?","answer_letter":"F","answer":"Target output values","explanation":"解析：答案为「Target output values」。"},{"id":197,"week":"Week 5.2 Part 2","question":"What is prediction (inference)?","answer_letter":"G","answer":"Predicting unseen examples","explanation":"解析：答案为「Predicting unseen examples」。"},{"id":198,"week":"Week 5.2 Part 2","question":"Why is sampling important in machine learning?","answer_letter":"L","answer":"Reduce dataset bias","explanation":"解析：答案为「Reduce dataset bias」。"},{"id":199,"week":"Week 5.2 Part 2","question":"What is stratified sampling used for?","answer_letter":"M","answer":"Preserve class proportions","explanation":"解析：答案为「Preserve class proportions」。"},{"id":200,"week":"Week 5.2 Part 2","question":"What is the purpose of test data?","answer_letter":"K","answer":"Evaluate model performance","explanation":"解析：答案为「Evaluate model performance」。"},{"id":201,"week":"Week 5.2 Part 2","question":"What does a machine learning model learn?","answer_letter":"I","answer":"Relationships in data","explanation":"解析：答案为「Relationships in data」。"},{"id":202,"week":"Week 5.2 Part 2","question":"What is the first step of the ML workflow?","answer_letter":"N","answer":"Data collection stage","explanation":"解析：答案为「Data collection stage」。"},{"id":203,"week":"Week 5.2 Part 2","question":"What type of problem predicts categories?","answer_letter":"D","answer":"Classification problem","explanation":"解析：答案为「Classification problem」。"},{"id":204,"week":"Week 5.2 Part 2","question":"What type of problem predicts numerical values?","answer_letter":"A","answer":"Regression problem","explanation":"解析：答案为「Regression problem」。"},{"id":205,"week":"Week 5.2 Part 2","question":"What is the main advantage of supervised learning?","answer_letter":"E","answer":"Predict outcomes from data","explanation":"解析：答案为「Predict outcomes from data」。"},{"id":206,"week":"Week 5.2 Part 2","question":"What type of data is required for supervised learning?","answer_letter":"J","answer":"Labeled training data","explanation":"解析：答案为「Labeled training data」。"},{"id":207,"week":"Week 5.2 Part 2","question":"What is the goal of unsupervised learning?","answer_letter":"B","answer":"Find hidden patterns","explanation":"解析：答案为「Find hidden patterns」。"},{"id":208,"week":"Week 5.2 Part 2","question":"Which learning approach uses rewards and penalties?","answer_letter":"C","answer":"Reinforcement learning approach","explanation":"解析：答案为「Reinforcement learning approach」。"},{"id":209,"week":"Week 5.2 Part 2","question":"What is a common healthcare application of supervised learning?","answer_letter":"O","answer":"Disease diagnosis systems","explanation":"解析：答案为「Disease diagnosis systems」。"},{"id":210,"week":"Week 6.1 Part 1","question":"What do learning curves help diagnose?","answer_letter":"E","answer":"Underfitting, overfitting, and data limitations","explanation":"解析：答案为「Underfitting, overfitting, and data limitations」。  过拟合指模型在训练集表现好但泛化差。"},{"id":211,"week":"Week 6.1 Part 1","question":"What is a hyperparameter?","answer_letter":"O","answer":"A value chosen before training that controls learning","explanation":"解析：答案为「A value chosen before training that controls learning」。"},{"id":212,"week":"Week 6.1 Part 1","question":"What is the main advantage of Grid Search?","answer_letter":"I","answer":"It evaluates every hyperparameter combination","explanation":"解析：答案为「It evaluates every hyperparameter combination」。"},{"id":213,"week":"Week 6.1 Part 1","question":"What is the main advantage of Random Search?","answer_letter":"A","answer":"It finds good solutions with fewer evaluations","explanation":"解析：答案为「It finds good solutions with fewer evaluations」。"},{"id":214,"week":"Week 6.1 Part 1","question":"What technique samples hyperparameter combinations randomly instead of testing all possibilities?","answer_letter":"F","answer":"Random Search","explanation":"解析：答案为「Random Search」。"},{"id":215,"week":"Week 6.1 Part 1","question":"What is the main goal of model evaluation and optimization?","answer_letter":"K","answer":"Improve generalization, performance, and reliability","explanation":"解析：答案为「Improve generalization, performance, and reliability」。"},{"id":216,"week":"Week 6.1 Part 1","question":"What problem occurs when a model learns the training data too closely, including noise?","answer_letter":"C","answer":"Overfitting","explanation":"解析：答案为「Overfitting」。  过拟合指模型在训练集表现好但泛化差。"},{"id":217,"week":"Week 6.1 Part 1","question":"What problem occurs when a model is too simple to capture underlying patterns?","answer_letter":"N","answer":"Underfitting","explanation":"解析：答案为「Underfitting」。"},{"id":218,"week":"Week 6.1 Part 1","question":"What is the primary objective of machine learning models?","answer_letter":"L","answer":"Generalize well to unseen data","explanation":"解析：答案为「Generalize well to unseen data」。"},{"id":219,"week":"Week 6.1 Part 1","question":"What technique penalizes overly complex models to reduce overfitting?","answer_letter":"G","answer":"Regularization","explanation":"解析：答案为「Regularization」。"},{"id":220,"week":"Week 6.1 Part 1","question":"Which regularization method uses the absolute value of coefficients?","answer_letter":"M","answer":"L1 (Lasso)","explanation":"解析：答案为「L1 (Lasso)」。  L1 正则化（Lasso）会产生稀疏解，可做特征选择。"},{"id":221,"week":"Week 6.1 Part 1","question":"Which regularization method uses the squared value of coefficients?","answer_letter":"H","answer":"L2 (Ridge)","explanation":"解析：答案为「L2 (Ridge)」。  L2 正则化（Ridge）对大权重施加更大惩罚，防止过拟合。"},{"id":222,"week":"Week 6.1 Part 1","question":"Why is a single train/test split often insufficient?","answer_letter":"B","answer":"Results may vary depending on the data split","explanation":"解析：答案为「Results may vary depending on the data split」。"},{"id":223,"week":"Week 6.1 Part 1","question":"What evaluation method divides data into k equal folds?","answer_letter":"D","answer":"K-Fold Cross-Validation","explanation":"解析：答案为「K-Fold Cross-Validation」。  交叉验证通过多次划分训练/验证集，得到更可靠的评估结果。"},{"id":224,"week":"Week 6.1 Part 1","question":"In K-Fold Cross-Validation, how many times is each fold used as the validation set?","answer_letter":"J","answer":"Once","explanation":"解析：答案为「Once」。"},{"id":225,"week":"Week 6.1 - Second Part Quiz Questions & Answers","question":"What is the first requirement for a good machine learning model?","answer_letter":"O","answer":"Generalize well to unseen data","explanation":"解析：答案为「Generalize well to unseen data」。"},{"id":226,"week":"Week 6.1 - Second Part Quiz Questions & Answers","question":"Why is training accuracy alone not enough?","answer_letter":"E","answer":"It does not measure performance on new data","explanation":"解析：答案为「It does not measure performance on new data」。"},{"id":227,"week":"Week 6.1 - Second Part Quiz Questions & Answers","question":"What problem occurs when a model is too simple?","answer_letter":"N","answer":"Underfitting","explanation":"解析：答案为「Underfitting」。"},{"id":228,"week":"Week 6.1 - Second Part Quiz Questions & Answers","question":"What problem occurs when a model learns noise in the training data?","answer_letter":"A","answer":"Overfitting","explanation":"解析：答案为「Overfitting」。  过拟合指模型在训练集表现好但泛化差。"},{"id":229,"week":"Week 6.1 - Second Part Quiz Questions & Answers","question":"What is the goal when balancing underfitting and overfitting?","answer_letter":"J","answer":"Good generalization","explanation":"解析：答案为「Good generalization」。"},{"id":230,"week":"Week 6.1 - Second Part Quiz Questions & Answers","question":"What basic evaluation method uses one train/test split?","answer_letter":"H","answer":"Train/Test Split","explanation":"解析：答案为「Train/Test Split」。"},{"id":231,"week":"Week 6.1 - Second Part Quiz Questions & Answers","question":"What evaluation method provides more robust results than a single split?","answer_letter":"B","answer":"K-Fold Cross-Validation","explanation":"解析：答案为「K-Fold Cross-Validation」。  交叉验证通过多次划分训练/验证集，得到更可靠的评估结果。"},{"id":232,"week":"Week 6.1 - Second Part Quiz Questions & Answers","question":"What hyperparameter is commonly tuned in KNN?","answer_letter":"M","answer":"Number of neighbors (k)","explanation":"解析：答案为「Number of neighbors (k)」。"},{"id":233,"week":"Week 6.1 - Second Part Quiz Questions & Answers","question":"What hyperparameter is commonly tuned in Decision Trees?","answer_letter":"I","answer":"Tree Depth","explanation":"解析：答案为「Tree Depth」。"},{"id":234,"week":"Week 6.1 - Second Part Quiz Questions & Answers","question":"What hyperparameter is commonly tuned in Neural Networks?","answer_letter":"C","answer":"Learning Rate","explanation":"解析：答案为「Learning Rate」。"},{"id":235,"week":"Week 6.1 - Second Part Quiz Questions & Answers","question":"What often has a greater impact than the choice of algorithm?","answer_letter":"L","answer":"Feature Engineering","explanation":"解析：答案为「Feature Engineering」。"},{"id":236,"week":"Week 6.1 - Second Part Quiz Questions & Answers","question":"Name one feature engineering technique discussed in the lecture.","answer_letter":"K","answer":"Polynomial Features","explanation":"解析：答案为「Polynomial Features」。"},{"id":237,"week":"Week 6.1 - Second Part Quiz Questions & Answers","question":"Which evaluation metrics are preferred for imbalanced datasets?","answer_letter":"F","answer":"Precision, Recall, and F1-Score","explanation":"解析：答案为「Precision, Recall, and F1-Score」。  精确率 = 正确预测的正样本 / 所有预测为正的样本。"},{"id":238,"week":"Week 6.1 - Second Part Quiz Questions & Answers","question":"What technique can improve minority-class detection in imbalanced datasets?","answer_letter":"G","answer":"SMOTE","explanation":"解析：答案为「SMOTE」。"},{"id":239,"week":"Week 6.1 - Second Part Quiz Questions & Answers","question":"Name one advanced machine learning model covered in this lecture.","answer_letter":"D","answer":"Gradient Boosting Machines (GBM)","explanation":"解析：答案为「Gradient Boosting Machines (GBM)」。"},{"id":240,"week":"Week 6.2 - First Part Quiz Questions & Answers","question":"What type of data is primarily used in unsupervised learning?","answer_letter":"D","answer":"Unlabeled data","explanation":"解析：答案为「Unlabeled data」。"},{"id":241,"week":"Week 6.2 - First Part Quiz Questions & Answers","question":"What is the main objective of unsupervised learning?","answer_letter":"L","answer":"Discover hidden patterns and structures","explanation":"解析：答案为「Discover hidden patterns and structures」。"},{"id":242,"week":"Week 6.2 - First Part Quiz Questions & Answers","question":"Which type of learning predicts known outcomes using labeled data?","answer_letter":"F","answer":"Supervised Learning","explanation":"解析：答案为「Supervised Learning」。  监督学习使用带标签的数据进行训练。"},{"id":243,"week":"Week 6.2 - First Part Quiz Questions & Answers","question":"What technique groups similar observations into meaningful clusters?","answer_letter":"C","answer":"Clustering","explanation":"解析：答案为「Clustering」。  聚类是无监督学习，将相似样本归为同一组。"},{"id":244,"week":"Week 6.2 - First Part Quiz Questions & Answers","question":"What unsupervised technique reduces the number of features while preserving important information?","answer_letter":"M","answer":"Dimensionality Reduction","explanation":"解析：答案为「Dimensionality Reduction」。"},{"id":245,"week":"Week 6.2 - First Part Quiz Questions & Answers","question":"What technique discovers relationships and co-occurrence patterns between variables?","answer_letter":"I","answer":"Association Rule Mining","explanation":"解析：答案为「Association Rule Mining」。"},{"id":246,"week":"Week 6.2 - First Part Quiz Questions & Answers","question":"Which unsupervised task identifies unusual observations that differ from normal behavior?","answer_letter":"J","answer":"Anomaly Detection","explanation":"解析：答案为「Anomaly Detection」。"},{"id":247,"week":"Week 6.2 - First Part Quiz Questions & Answers","question":"What is the center of a cluster in K-Means called?","answer_letter":"N","answer":"Centroid","explanation":"解析：答案为「Centroid」。"},{"id":248,"week":"Week 6.2 - First Part Quiz Questions & Answers","question":"Which distance metric is most commonly used in K-Means?","answer_letter":"O","answer":"Euclidean Distance","explanation":"解析：答案为「Euclidean Distance」。"},{"id":249,"week":"Week 6.2 - First Part Quiz Questions & Answers","question":"What does the parameter k represent in K-Means clustering?","answer_letter":"H","answer":"Number of clusters","explanation":"解析：答案为「Number of clusters」。  聚类是无监督学习，将相似样本归为同一组。"},{"id":250,"week":"Week 6.2 - First Part Quiz Questions & Answers","question":"Which method helps determine the optimal value of K in K-Means?","answer_letter":"E","answer":"Elbow Method","explanation":"解析：答案为「Elbow Method」。"},{"id":251,"week":"Week 6.2 - First Part Quiz Questions & Answers","question":"What is the name of the tree-like structure produced by Hierarchical Clustering?","answer_letter":"B","answer":"Dendrogram","explanation":"解析：答案为「Dendrogram」。"},{"id":252,"week":"Week 6.2 - First Part Quiz Questions & Answers","question":"In Hierarchical Clustering, what does a low merge height indicate?","answer_letter":"K","answer":"Very similar observations","explanation":"解析：答案为「Very similar observations」。"},{"id":253,"week":"Week 6.2 - First Part Quiz Questions & Answers","question":"What problem occurs when distances become less meaningful as the number of features increases?","answer_letter":"G","answer":"Curse of Dimensionality","explanation":"解析：答案为「Curse of Dimensionality」。"},{"id":254,"week":"Week 6.2 - First Part Quiz Questions & Answers","question":"Which dimensionality reduction technique projects data onto directions that maximize variance?","answer_letter":"A","answer":"PCA (Principal Component Analysis)","explanation":"解析：答案为「PCA (Principal Component Analysis)」。  PCA 通过找最大方差方向降低数据维度。"},{"id":255,"week":"Week 6.2 - Second Part Quiz Questions & Answers","question":"What is the main goal of PCA?","answer_letter":"A","answer":"Reduce dimensionality while preserving important information","explanation":"解析：答案为「Reduce dimensionality while preserving important information」。"},{"id":256,"week":"Week 6.2 - Second Part Quiz Questions & Answers","question":"Which principal component captures the largest amount of variation in the data?","answer_letter":"C","answer":"PC1","explanation":"解析：答案为「PC1」。"},{"id":257,"week":"Week 6.2 - Second Part Quiz Questions & Answers","question":"What percentage of variance is preserved by PC1 and PC2 together in the PCA example?","answer_letter":"M","answer":"84%","explanation":"解析：答案为「84%」。"},{"id":258,"week":"Week 6.2 - Second Part Quiz Questions & Answers","question":"Which dimensionality reduction technique is linear and highly interpretable?","answer_letter":"I","answer":"PCA","explanation":"解析：答案为「PCA」。  PCA 通过找最大方差方向降低数据维度。"},{"id":259,"week":"Week 6.2 - Second Part Quiz Questions & Answers","question":"Which dimensionality reduction technique is non-linear and excels at visualization?","answer_letter":"J","answer":"t-SNE","explanation":"解析：答案为「t-SNE」。"},{"id":260,"week":"Week 6.2 - Second Part Quiz Questions & Answers","question":"What does Association Rule Mining discover in a dataset?","answer_letter":"H","answer":"Relationships between items","explanation":"解析：答案为「Relationships between items」。"},{"id":261,"week":"Week 6.2 - Second Part Quiz Questions & Answers","question":"What metric measures how frequently a rule appears in a dataset?","answer_letter":"K","answer":"Support","explanation":"解析：答案为「Support」。"},{"id":262,"week":"Week 6.2 - Second Part Quiz Questions & Answers","question":"What metric measures how reliable an association rule is?","answer_letter":"O","answer":"Confidence","explanation":"解析：答案为「Confidence」。"},{"id":263,"week":"Week 6.2 - Second Part Quiz Questions & Answers","question":"What does a Lift value greater than 1 indicate?","answer_letter":"G","answer":"Positive association between items","explanation":"解析：答案为「Positive association between items」。"},{"id":264,"week":"Week 6.2 - Second Part Quiz Questions & Answers","question":"In the rule {Diapers} → {Beer}, what does Confidence represent?","answer_letter":"B","answer":"Probability of buying beer given diapers","explanation":"解析：答案为「Probability of buying beer given diapers」。"},{"id":265,"week":"Week 6.2 - Second Part Quiz Questions & Answers","question":"What is the main purpose of the Apriori algorithm?","answer_letter":"D","answer":"Discover frequent itemsets and association rules","explanation":"解析：答案为「Discover frequent itemsets and association rules」。"},{"id":266,"week":"Week 6.2 - Second Part Quiz Questions & Answers","question":"What type of business application groups customers according to purchasing behavior?","answer_letter":"E","answer":"Customer Segmentation","explanation":"解析：答案为「Customer Segmentation」。"},{"id":267,"week":"Week 6.2 - Second Part Quiz Questions & Answers","question":"What is the primary goal of Anomaly Detection?","answer_letter":"N","answer":"Identify rare or unusual observations","explanation":"解析：答案为「Identify rare or unusual observations」。"},{"id":268,"week":"Week 6.2 - Second Part Quiz Questions & Answers","question":"What is the bottleneck or latent space in an autoencoder?","answer_letter":"F","answer":"Compressed representation of the data","explanation":"解析：答案为「Compressed representation of the data」。"},{"id":269,"week":"Week 6.2 - Second Part Quiz Questions & Answers","question":"What is one major challenge of unsupervised learning?","answer_letter":"L","answer":"Evaluating results without ground truth labels","explanation":"解析：答案为「Evaluating results without ground truth labels」。"}]